{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": {
          "tool_name": "Grep|Glob|Bash"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(npm root -g)/gitnexus/hooks/claude/gitnexus-hook.cjs\"",
            "timeout": 8000
          }
        ]
      }
    ]
  }
}
